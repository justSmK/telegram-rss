    <title type="html">Вопрос для тех, кто юзает AI для работы: что ближе всего к тебе, подумай.</title>
    <published>2026-02-02T17:59:04+00:00</published>
    <updated>2026-02-02T17:59:04+00:00</updated>
    <id>https://t.me/iOSRoadmapHub/334</id>
    <link rel="alternate" type="text/html" href="https://t.me/iOSRoadmapHub/334"/>
    <author>
