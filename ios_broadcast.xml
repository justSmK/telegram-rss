    <title type="html">💻 Apple представила MacBook Neo — самый доступный ноутбук...</title>
    <published>2026-03-04T14:58:32+00:00</published>
    <updated>2026-03-04T14:58:32+00:00</updated>
    <id>https://t.me/ios_broadcast/2623</id>
    <link rel="alternate" type="text/html" href="https://t.me/ios_broadcast/2623"/>
    <author>
