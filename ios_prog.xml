  <entry>
    <title type="html">В Xcode завезли нативную поддержку Claude Agent SDK.&#13;
&#13;
Apple...</title>
    <published>2026-02-04T06:08:24+00:00</published>
    <updated>2026-02-04T06:08:24+00:00</updated>
    <id>https://t.me/ios_prog/707</id>
    <link rel="alternate" type="text/html" href="https://t.me/ios_prog/707"/>
